generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== MULTI-TENANCY & AUTH ====================

model Tenant {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  rtNumber   String
  rwNumber   String
  kelurahan  String?
  kecamatan  String?
  kota       String?
  provinsi   String?
  address    String?
  phone      String?
  email      String?
  logo       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subscription        Subscription?
  paymentTransactions PaymentTransaction[]
  users               User[]
  rumah           Rumah[]
  warga           Warga[]
  keluarga        Keluarga[]
  tamu            Tamu[]
  kendaraan       Kendaraan[]
  surat           Surat[]
  kasTransactions KasTransaction[]
  iuranTypes      IuranType[]
  iuranPayments   IuranPayment[]
  agenda          Agenda[]
  berita          Berita[]
  bansos          Bansos[]
  bansosRecipients BansosRecipient[]
  siskamling      Siskamling[]
  keluhan         Keluhan[]
  pengajuan       Pengajuan[]
  inventaris      Inventaris[]
  organisasi      Organisasi[]
  usahaWarga      UsahaWarga[]
  iklan           IklanUsaha[]
  ppobOrders      PPOBOrder[]
  pembangunan     Pembangunan[]
  posSecurityLogs PosSecurityLog[]
  tataTertib      TataTertib[]
  programKerja    ProgramKerja[]
  berkas          Berkas[]
  covid19Data     Covid19Data[]
  vaksinasiData   VaksinasiData[]

  @@index([slug])
}

enum SubscriptionTier {
  TIER_A
  TIER_B
  TIER_C
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum PaymentProvider {
  STRIPE
  MIDTRANS
  XENDIT
  MANUAL
}

enum PaymentTransactionStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  tier                 SubscriptionTier   @default(TIER_A)
  status               SubscriptionStatus @default(TRIALING)
  paymentProvider      PaymentProvider    @default(MANUAL)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PaymentTransaction {
  id         String                   @id @default(cuid())
  tenantId   String
  orderId    String                   @unique
  provider   PaymentProvider
  externalId String?                  // Provider's transaction/invoice ID
  amount     Decimal                  @db.Decimal(15, 2)
  currency   String                   @default("IDR")
  tier       SubscriptionTier
  status     PaymentTransactionStatus @default(PENDING)
  snapToken  String?                  // Midtrans Snap token
  paymentUrl String?
  paidAt     DateTime?
  expiredAt  DateTime?
  metadata   Json?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@index([externalId])
  @@index([provider, status])
}

enum UserRole {
  SUPER_ADMIN
  RT_ADMIN
  RW_ADMIN
  RESIDENT
}

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  keluargaId    String?   // Link ke KK — semua anggota KK bisa pakai akun yang sama
  email         String    @unique
  emailVerified DateTime?
  password      String
  name          String
  phone         String?
  avatar        String?
  role          UserRole  @default(RESIDENT)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  keluarga Keluarga? @relation("UserKeluarga", fields: [keluargaId], references: [id])
  warga    Warga?    @relation("UserWarga")

  @@index([tenantId])
  @@index([email])
  @@index([keluargaId])
}

// ==================== RESIDENTIAL DATA ====================

enum StatusHuni {
  DIHUNI
  TIDAK_DIHUNI
  DISEWAKAN
}

enum StatusMilik {
  MILIK_SENDIRI
  SEWA
  KONTRAK
  LAINNYA
}

model Rumah {
  id           String      @id @default(cuid())
  tenantId     String
  nomorRumah   String
  blok         String?
  alamat       String
  rt           String?
  rw           String?
  statusHuni   StatusHuni  @default(DIHUNI)
  statusMilik  StatusMilik @default(MILIK_SENDIRI)
  luasTanah    Float?
  luasBangunan Float?
  latitude     Float?
  longitude    Float?
  foto         String?
  catatan      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  keluarga Keluarga[]
  kendaraan Kendaraan[]

  @@unique([tenantId, nomorRumah, blok])
  @@index([tenantId])
}

model Keluarga {
  id             String   @id @default(cuid())
  tenantId       String
  rumahId        String
  nomorKK        String
  kepalaKeluarga String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rumah   Rumah   @relation(fields: [rumahId], references: [id])
  anggota Warga[]
  users   User[]  @relation("UserKeluarga")

  @@unique([tenantId, nomorKK])
  @@index([tenantId])
}

enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

enum Agama {
  ISLAM
  KRISTEN
  KATOLIK
  HINDU
  BUDDHA
  KONGHUCU
  LAINNYA
}

enum StatusPerkawinan {
  BELUM_KAWIN
  KAWIN
  CERAI_HIDUP
  CERAI_MATI
}

enum StatusTinggal {
  TETAP
  KONTRAK
  KOST
  LAINNYA
}

enum StatusAktifWarga {
  AKTIF
  PINDAH
  MENINGGAL
  TIDAK_AKTIF
}

model Warga {
  id                  String            @id @default(cuid())
  tenantId            String
  keluargaId          String?
  userId              String?           @unique
  nik                 String
  namaLengkap         String
  tempatLahir         String?
  tanggalLahir        DateTime?
  jenisKelamin        JenisKelamin?
  golonganDarah       String?
  agama               Agama?
  statusPerkawinan    StatusPerkawinan?
  pekerjaan           String?
  pendidikan          String?
  kewarganegaraan     String?           @default("WNI")
  nomorHP             String?
  email               String?
  foto                String?
  statusTinggal       StatusTinggal     @default(TETAP)
  statusAktif         StatusAktifWarga  @default(AKTIF)
  tanggalMasuk        DateTime?
  tanggalKeluar       DateTime?
  alamatPindah        String?
  keteranganPindah    String?
  tanggalMeninggal    DateTime?
  keteranganMeninggal String?
  isPemilih           Boolean           @default(false)
  catatan             String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  keluarga         Keluarga?         @relation(fields: [keluargaId], references: [id])
  user             User?             @relation("UserWarga", fields: [userId], references: [id])
  iuranPayments    IuranPayment[]
  bansosRecipients BansosRecipient[]
  suratList        Surat[]           @relation("SuratWarga")
  keluhan          Keluhan[]         @relation("KeluhanWarga")
  pengajuan        Pengajuan[]       @relation("PengajuanWarga")
  berita           Berita[]          @relation("BeritaWarga")
  ppobOrders       PPOBOrder[]       @relation("PPOBWarga")
  vaksinasi        VaksinasiData[]

  @@unique([tenantId, nik])
  @@index([tenantId])
  @@index([tenantId, statusAktif])
}

model Tamu {
  id              String    @id @default(cuid())
  tenantId        String
  namaLengkap     String
  nik             String?
  alamatAsal      String
  tujuan          String
  wargaDikunjungi String
  nomorHP         String?
  nomorKendaraan  String?
  foto            String?
  waktuDatang     DateTime  @default(now())
  waktuPulang     DateTime?
  catatan         String?
  createdAt       DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, waktuDatang])
}

enum JenisKendaraan {
  MOTOR
  MOBIL
  SEPEDA
  LAINNYA
}

model Kendaraan {
  id             String         @id @default(cuid())
  tenantId       String
  rumahId        String?
  pemilik        String
  jenisKendaraan JenisKendaraan
  merek          String?
  nomorPolisi    String
  warna          String?
  tahun          Int?
  stnkBerlaku    DateTime?
  foto           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rumah  Rumah? @relation(fields: [rumahId], references: [id])

  @@index([tenantId])
}

// ==================== CORRESPONDENCE ====================

enum JenisSurat {
  SURAT_PENGANTAR
  SURAT_KETERANGAN
  SURAT_DOMISILI
  SURAT_TIDAK_MAMPU
  SURAT_KEMATIAN
  SURAT_KELAHIRAN
  SURAT_PINDAH
  SURAT_USAHA
  LAINNYA
}

enum StatusSurat {
  DIAJUKAN
  DIPROSES
  DISETUJUI
  DITOLAK
}

model Surat {
  id               String      @id @default(cuid())
  tenantId         String
  wargaId          String?
  nomorSurat       String
  jenisSurat       JenisSurat
  perihal          String
  isiSurat         String?
  status           StatusSurat @default(DIAJUKAN)
  tanggalSurat     DateTime    @default(now())
  tanggalDisetujui DateTime?
  disetujuiOleh    String?
  tandaTangan      String?
  catatan          String?
  fileUrl          String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warga  Warga? @relation("SuratWarga", fields: [wargaId], references: [id])

  @@index([tenantId])
  @@index([tenantId, jenisSurat])
}

// ==================== FINANCE ====================

enum JenisKas {
  MASUK
  KELUAR
}

model KasTransaction {
  id         String   @id @default(cuid())
  tenantId   String
  tanggal    DateTime @default(now())
  jenis      JenisKas
  kategori   String
  keterangan String
  jumlah     Decimal  @db.Decimal(15, 2)
  buktiUrl   String?
  pencatat   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, tanggal])
  @@index([tenantId, jenis])
}

enum PeriodeIuran {
  BULANAN
  TAHUNAN
  INSIDENTAL
  DONASI
}

model IuranType {
  id                String       @id @default(cuid())
  tenantId          String
  nama              String
  jumlah            Decimal      @db.Decimal(15, 2)
  periode           PeriodeIuran @default(BULANAN)
  isActive          Boolean      @default(true)
  deskripsi         String?
  isJumlahFleksibel Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments IuranPayment[]

  @@unique([tenantId, nama])
  @@index([tenantId])
}

enum MetodeBayar {
  TUNAI
  TRANSFER
  EWALLET
  LAINNYA
}

model IuranPayment {
  id          String       @id @default(cuid())
  tenantId    String
  iuranTypeId String
  wargaId     String
  bulan       Int
  tahun       Int
  jumlah      Decimal      @db.Decimal(15, 2)
  tanggalBayar DateTime?
  metodeBayar  MetodeBayar?
  buktiUrl    String?
  pencatat    String?
  catatan     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  iuranType IuranType @relation(fields: [iuranTypeId], references: [id])
  warga     Warga     @relation(fields: [wargaId], references: [id])

  @@unique([tenantId, iuranTypeId, wargaId, bulan, tahun])
  @@index([tenantId])
  @@index([tenantId, tahun, bulan])
}

// ==================== COMMUNITY FEATURES ====================

model Agenda {
  id             String    @id @default(cuid())
  tenantId       String
  judul          String
  deskripsi      String?
  tanggalMulai   DateTime
  tanggalSelesai DateTime?
  lokasi         String?
  foto           String[]
  isPublished    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Berita {
  id          String    @id @default(cuid())
  tenantId    String
  wargaId     String?
  judul       String
  slug        String
  konten      String
  ringkasan   String?
  gambar      String?
  kategori    String?
  penulis     String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warga  Warga?  @relation("BeritaWarga", fields: [wargaId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId])
}

enum StatusBansos {
  AKTIF
  SELESAI
  DIBATALKAN
}

model Bansos {
  id             String       @id @default(cuid())
  tenantId       String
  nama           String
  sumber         String
  deskripsi      String?
  tanggalMulai   DateTime
  tanggalSelesai DateTime?
  status         StatusBansos @default(AKTIF)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipients BansosRecipient[]

  @@index([tenantId])
}

model BansosRecipient {
  id            String    @id @default(cuid())
  tenantId      String
  bansosId      String
  wargaId       String
  tanggalTerima DateTime?
  jumlah        String?
  catatan       String?
  createdAt     DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bansos Bansos @relation(fields: [bansosId], references: [id], onDelete: Cascade)
  warga  Warga  @relation(fields: [wargaId], references: [id])

  @@unique([bansosId, wargaId])
  @@index([tenantId])
}

model Siskamling {
  id       String   @id @default(cuid())
  tenantId String
  tanggal  DateTime
  shift    String?
  petugas  String[]
  lokasi   String?
  catatan  String?
  kejadian String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, tanggal])
}

enum StatusKeluhan {
  BARU
  DIPROSES
  SELESAI
  DITOLAK
}

model Keluhan {
  id             String        @id @default(cuid())
  tenantId       String
  wargaId        String?
  pengirim       String
  email          String?
  kategori       String
  judul          String
  isi            String
  fotoUrl        String?
  latitude       Float?
  longitude      Float?
  isUrgent       Boolean       @default(false)
  status         StatusKeluhan @default(BARU)
  tanggapan      String?
  tanggalTanggap DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warga  Warga?  @relation("KeluhanWarga", fields: [wargaId], references: [id])

  @@index([tenantId])
  @@index([tenantId, isUrgent])
}

// ─── Pengajuan ────────────────────────────────────────────────────────────────

enum StatusPengajuan {
  MENUNGGU
  DIPROSES
  DISETUJUI
  DITOLAK
}

model Pengajuan {
  id             String          @id @default(cuid())
  tenantId       String
  wargaId        String?
  pengirim       String
  kategori       String
  judul          String
  isi            String
  status         StatusPengajuan @default(MENUNGGU)
  tanggapan      String?
  tanggalTanggap DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warga  Warga?  @relation("PengajuanWarga", fields: [wargaId], references: [id])

  @@index([tenantId])
}

model Inventaris {
  id               String    @id @default(cuid())
  tenantId         String
  namaBarang       String
  kategori         String?
  jumlah           Int       @default(1)
  kondisi          String?
  lokasi           String?
  tanggalPerolehan DateTime?
  nilaiPerolehan   Decimal?  @db.Decimal(15, 2)
  catatan          String?
  foto             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Organisasi {
  id       String   @id @default(cuid())
  tenantId String
  nama     String
  jabatan  String
  urutan   Int      @default(0)
  foto     String?
  nomorHP  String?
  periode  String?
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ==================== TIER B+ FEATURES ====================

model UsahaWarga {
  id            String   @id @default(cuid())
  tenantId      String
  namaUsaha     String
  pemilik       String
  jenis         String
  alamat        String?
  nomorHP       String?
  deskripsi     String?
  foto          String?
  isActive      Boolean  @default(true)
  isMarketplace Boolean  @default(false)
  products      Product[]
  iklan         IklanUsaha[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isMarketplace, isActive])
}

model Product {
  id           String   @id @default(cuid())
  usahaWargaId String
  nama         String
  deskripsi    String?
  harga        Decimal  @db.Decimal(15, 2)
  foto         String?
  kategori     String?
  stok         Int?
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  usahaWarga UsahaWarga @relation(fields: [usahaWargaId], references: [id], onDelete: Cascade)

  @@index([usahaWargaId])
}

// ─── Iklan / Ad Slots ─────────────────────────────────────────────────────────

enum StatusIklan {
  MENUNGGU_BAYAR
  AKTIF
  KADALUARSA
  DITOLAK
}

model IklanUsaha {
  id              String     @id @default(cuid())
  tenantId        String
  usahaWargaId    String
  durasi          Int        // days: 7 / 14 / 30
  harga           Decimal    @db.Decimal(15, 2)
  status          StatusIklan @default(MENUNGGU_BAYAR)
  mulaiTayang     DateTime?
  selesaiTayang   DateTime?
  buktiPembayaran String?
  catatan         String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usahaWarga UsahaWarga @relation(fields: [usahaWargaId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

// ─── PPOB Orders ─────────────────────────────────────────────────────────────

enum JenisPPOB {
  PLN
  PDAM
  PULSA
  BPJS_KESEHATAN
  BPJS_KETENAGAKERJAAN
  INTERNET
  TV_KABEL
  LAINNYA
}

enum StatusPPOB {
  MENUNGGU
  DIPROSES
  BERHASIL
  GAGAL
}

model PPOBOrder {
  id           String    @id @default(cuid())
  tenantId     String
  wargaId      String?
  pemohon      String
  jenis        JenisPPOB
  nomorTujuan  String
  jumlah       Decimal   @db.Decimal(15, 2)
  adminFee     Decimal   @db.Decimal(15, 2) @default(0)
  total        Decimal   @db.Decimal(15, 2)
  status       StatusPPOB @default(MENUNGGU)
  catatan      String?
  buktiUrl     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warga  Warga? @relation("PPOBWarga", fields: [wargaId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
}

enum StatusPembangunan {
  DIUSULKAN
  DISETUJUI
  DALAM_PROSES
  SELESAI
  DITOLAK
}

model Pembangunan {
  id            String            @id @default(cuid())
  tenantId      String
  judul         String
  deskripsi     String?
  pengusul      String
  estimasiBiaya Decimal?          @db.Decimal(15, 2)
  lokasi        String?
  status        StatusPembangunan @default(DIUSULKAN)
  catatan       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ==================== TIER C ONLY ====================

model PosSecurityLog {
  id              String   @id @default(cuid())
  tenantId        String
  tanggal         DateTime @default(now())
  petugas         String
  shift           String?
  kejadian        String?
  tamuMasuk       Int      @default(0)
  tamuKeluar      Int      @default(0)
  kendaraanMasuk  Int      @default(0)
  kendaraanKeluar Int      @default(0)
  catatan         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, tanggal])
}

// ==================== MISC ====================

model TataTertib {
  id       String   @id @default(cuid())
  tenantId String
  judul    String
  isi      String
  urutan   Int      @default(0)
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

