# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://rtuser:rtpass@localhost:5432/rt_online"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="RT Online"

# ─── Payment Gateway (aktifkan minimal 1 provider) ────────────────────────────
# Provider default jika tidak disebutkan saat checkout (MIDTRANS | XENDIT | STRIPE)
PAYMENT_PROVIDER="MIDTRANS"

# ── Midtrans ─────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxxxxxxxx"   # Server key (rahasia, hanya di server)
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxxxxxxxx"   # Client key (boleh publik)
MIDTRANS_IS_PRODUCTION="false"                      # Ganti "true" untuk produksi
# Notification URL di Midtrans dashboard:
#   Settings → Configuration → Payment Notification URL
#   → https://yourdomain.com/api/webhooks/midtrans

# ── Xendit ───────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.xendit.co → Settings → API Keys
XENDIT_SECRET_KEY="xnd_development_xxxxxxxxxxxx"
# Webhook Token di Xendit dashboard:
#   Settings → Callbacks → Verification Token
XENDIT_WEBHOOK_TOKEN="your-xendit-webhook-token"
# Callback URL di Xendit:
#   Settings → Callbacks → Invoice → https://yourdomain.com/api/webhooks/xendit

# ── Stripe ───────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook Secret dari: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs dari Stripe dashboard (Products → Prices)
STRIPE_PRICE_TIER_A="price_..."
STRIPE_PRICE_TIER_B="price_..."
STRIPE_PRICE_TIER_C="price_..."
